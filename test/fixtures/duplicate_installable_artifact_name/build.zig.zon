    .paths = .{ "build.zig", "build.zig.zon", "src" },
    .dependencies = .{
        .zbuild = .{ .path = "../../.." },
    },
    .executables = .{
        .shared = .{
            .root_module = .{
                .name = "shared_exe_root",
                .root_source_file = "src/main.zig",
            },
        },
    },
    .libraries = .{
