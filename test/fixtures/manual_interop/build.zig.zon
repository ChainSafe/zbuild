.{
    .name = .manual_interop,
    .version = "0.1.0",
    .fingerprint = 0xb6f4a41579e23c4e,
    .minimum_zig_version = "0.16.0",
    .paths = .{ "build.zig", "build.zig.zon", "src" },
    .dependencies = .{
        .zbuild = .{ .path = "../../.." },
    },
    .modules = .{
        .core = .{
            .root_source_file = "src/core.zig",
            .imports = .{.{ .external_module = "shared" }},
        },
    },
    .executables = .{
        .myapp = .{
            .root_module = .{
                .root_source_file = "src/main.zig",
                .imports = .{ .core, .{ .external_module = "shared" } },
            },
            .depends_on = .{.{ .external_step = "gen:prep" }},
        },
        .shared_exe = .{
            .root_module = .{ .external_module = "shared" },
        },
    },
    .runs = .{
        .demo = .{
            .cmd = .{ "echo", "manual interop ok" },
            .depends_on = .{.{ .external_step = "gen:prep" }},
        },
    },
}
