.{
    .name = .stdlib_passthrough,
    .version = "0.1.0",
    .fingerprint = 0xb7f75f47342d3f61,
    .minimum_zig_version = "0.16.0",
    .paths = .{ "build.zig", "build.zig.zon", "src", "bin" },
    .dependencies = .{
        .zbuild = .{ .path = "../../.." },
    },
    .modules = .{
        .core = .{
            .root_source_file = "src/core.zig",
            .no_builtin = false,
        },
    },
    .libraries = .{
        .mylib = .{
            .root_module = .core,
            .win32_module_definition = "src/mylib.def",
        },
    },
    .tests = .{
        .unit = .{
            .root_module = .{
                .root_source_file = "src/test.zig",
                .imports = .{.core},
            },
            .test_runner = .{
                .path = "bin/test_runner.zig",
                .mode = .simple,
            },
            .emit_object = false,
        },
    },
}
